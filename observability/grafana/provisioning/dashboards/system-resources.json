{
  "uid": "system-resources",
  "title": "System Resources — JVM & Containers",
  "tags": ["jvm", "resources", "cpu", "memory"],
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(bucket4j_jvm_memory_used_bytes, job)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "label": "Service"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (job, instance) (rate(bucket4j_process_cpu_usage[1m])) * 100",
          "legendFormat": "{{job}} — {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage (Bytes)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (job, area) (bucket4j_jvm_memory_used_bytes{job=~\"$service\"})",
          "legendFormat": "{{job}} — {{area}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "title": "Live Thread Count",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (job) (bucket4j_jvm_threads_live_threads{job=~\"$service\"})",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 4,
      "title": "Garbage Collection Time (Rate)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (job, gc) (rate(bucket4j_jvm_gc_pause_seconds_sum{job=~\"$service\"}[1m]))",
          "legendFormat": "{{job}} — {{gc}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    }
  ]
}
