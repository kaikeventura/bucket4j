{
  "uid": "bucket4j-overview",
  "title": "Bucket4j — Payment Pipeline",
  "tags": ["bucket4j", "payments"],
  "schemaVersion": 38,
  "version": 5,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(bucket4j_tickets_processed_total, service_name)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "label": "Service"
      }
    ]
  },
  "panels": [
    {
      "id": 10,
      "title": "Live Pipeline Status (TPS)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bucket4j_tickets_received_total{service_name=\"ticket-sales-processor\"}[1m]))",
          "legendFormat": "Java In (from SQS)"
        },
        {
          "expr": "sum(rate(bucket4j_tickets_processed_total{service_name=\"ticket-sales-processor\"}[1m]))",
          "legendFormat": "Java Out (to Kafka)"
        },
        {
          "expr": "sum(rate(bucket4j_tickets_received_total{service_name=\"payment-processor-fake\"}[1m]))",
          "legendFormat": "Go In (from Kafka)"
        },
        {
          "expr": "sum(rate(bucket4j_tickets_processed_total{service_name=\"payment-processor-fake\"}[1m]))",
          "legendFormat": "Go Out (Finished)"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 8.5 },
              { "color": "red", "value": 11 }
            ]
          }
        }
      }
    },
    {
      "id": 1,
      "title": "Detailed Pipeline Throughput (TPS)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bucket4j_tickets_processed_total{service_name=\"ticket-sales-processor\"}[1m]))",
          "legendFormat": "1. Java Sent to Kafka"
        },
        {
          "expr": "sum(rate(bucket4j_tickets_received_total{service_name=\"payment-processor-fake\"}[1m]))",
          "legendFormat": "2. Go Received from Kafka"
        },
        {
          "expr": "sum(rate(bucket4j_tickets_processed_total{service_name=\"payment-processor-fake\"}[1m]))",
          "legendFormat": "3. Go Finished Processing"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 10.1 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull", "max"] }
      }
    },
    {
      "id": 2,
      "title": "Bucket4j Global Wait Time (p95 s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(bucket4j_bucket4j_wait_time_bucket[1m])))",
          "legendFormat": "Java Wait Time p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 7,
      "title": "Service Processing Latency (p95 s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(bucket4j_processing_duration_bucket[1m])))",
          "legendFormat": "p95 {{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 5,
      "title": "Pipeline Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=~\"$service\"} | json",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}
