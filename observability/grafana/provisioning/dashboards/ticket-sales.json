{
  "uid": "bucket4j-overview",
  "title": "Bucket4j — Payment Pipeline",
  "tags": ["bucket4j", "payments"],
  "schemaVersion": 38,
  "version": 3,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(bucket4j_tickets_processed_total, service_name)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "label": "Service"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Global Throughput (TPS) — Processed",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(bucket4j_tickets_processed_total[1m]))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "drawStyle": "line" } }
      }
    },
    {
      "id": 6,
      "title": "Payment Processor Fake — Received vs Processed",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bucket4j_tickets_received_total{service_name=\"payment-processor-fake\"}[1m]))",
          "legendFormat": "Received (TPS)"
        },
        {
          "expr": "sum(rate(bucket4j_tickets_processed_total{service_name=\"payment-processor-fake\"}[1m]))",
          "legendFormat": "Processed (TPS)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 2,
      "title": "Bucket4j Wait Time — Java App (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(bucket4j_bucket4j_wait_time_bucket[1m])))",
          "legendFormat": "Wait Time p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum by (service_name) (rate(bucket4j_tickets_processed_total{status=\"FAILED\"}[1m])) / sum by (service_name) (rate(bucket4j_tickets_processed_total[1m]))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Processing Duration — Java vs Go (p95 s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(bucket4j_processing_duration_bucket[1m])))",
          "legendFormat": "p95 {{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 5,
      "title": "Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=~\"$service\"} | json",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}
