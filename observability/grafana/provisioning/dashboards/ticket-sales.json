{
  "uid": "bucket4j-overview",
  "title": "Bucket4j — Payment Pipeline",
  "tags": ["bucket4j", "payments"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(bucket4j_tickets_processed_total, service_name)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "label": "Service"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Tickets Processed — Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service_name, status) (rate(bucket4j_tickets_processed_total[1m]))",
          "legendFormat": "{{service_name}} — {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 2,
      "title": "Processing Duration — p50 / p95 / p99 (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, service_name) (rate(bucket4j_processing_duration_seconds_bucket[1m])))",
          "legendFormat": "p50 {{service_name}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(bucket4j_processing_duration_seconds_bucket[1m])))",
          "legendFormat": "p95 {{service_name}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, service_name) (rate(bucket4j_processing_duration_seconds_bucket[1m])))",
          "legendFormat": "p99 {{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum by (service_name) (rate(bucket4j_tickets_processed_total{status=\"FAILED\"}[1m])) / sum by (service_name) (rate(bucket4j_tickets_processed_total[1m]))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Traces — Search",
      "type": "traces",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\"}",
          "limit": 20
        }
      ]
    },
    {
      "id": 5,
      "title": "Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=~\"$service\"} | json",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}
